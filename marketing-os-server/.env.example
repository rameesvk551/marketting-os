# Environment
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/travel_ops
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ============================================
# Billing / Razorpay
# ============================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_MONTHLY_PLAN_ID=
RAZORPAY_YEARLY_PLAN_ID=
BILLING_USAGE_CRON_ENABLED=true
# UTC schedule, default: 03:00 on day 1 of each month
BILLING_USAGE_CRON_SCHEDULE=0 3 1 * *

# Tenant
DEFAULT_TENANT_SLUG=default

# CORS
CORS_ORIGIN=http://localhost:3000

# ============================================
# WhatsApp Configuration
# ============================================

# Provider: 'meta' | 'twilio' | 'vonage' | 'mock'
WHATSAPP_PROVIDER=mock

# Meta (Facebook) WhatsApp Cloud API
# Get these from Meta Business Suite > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_VERSION=v18.0

# Meta App credentials (required for Facebook Login + Embedded Signup)
META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=
# Optional override (default: /api/v1/whatsapp/onboard/callback)
META_EMBEDDED_SIGNUP_REDIRECT_URI=

# System user credentials (for managed/shared WABA mode)
META_SYSTEM_USER_TOKEN=
META_APP_WABA_ID=

# Encrypts tenant access tokens at rest (required in production)
WHATSAPP_TOKEN_ENCRYPTION_KEY=change-this-to-a-strong-random-secret

# Webhook security
# App Secret from Meta Developer Console
WHATSAPP_APP_SECRET=
# Custom verify token (you create this, use during webhook setup)
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
